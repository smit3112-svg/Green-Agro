# Copy this file to .env and fill in your real values.
# Never commit .env to version control!

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/green_agro?retryWrites=true&w=majority

# Optional: override the database name (default: green_agro)
DB_NAME=green_agro

# Admin login credentials (set these in Render/Koyeb dashboard)
ADMIN_USER=your_admin_username
ADMIN_PASS=your_strong_password

# Optional: override the port (Render/Koyeb set PORT automatically)
# PORT=8000
